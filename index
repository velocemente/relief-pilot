// ═══════════════════════════════════════════════════════
//  OEI RUNWAY PICKER
// ═══════════════════════════════════════════════════════

function openOeiPicker() {
  const overlay = document.getElementById('oeiOverlay');
  const list    = document.getElementById('oeiRwyList');
  if (!overlay || !list) return;

  const data = S.oeiData || [];
  if (!data.length) return;  // no TLR parsed — fallback to legacy ev()

  list.innerHTML = '';
  data.forEach(d => {
    const row = document.createElement('div');
    row.className = 'oei-rwy-row' + (d.rwy === S.oeiSelectedRwy ? ' selected' : '');
    row.setAttribute('role', 'button');
    row.setAttribute('aria-label', `Runway ${d.rwy}: ${d.coChart ? 'SEE CO CHART' : d.special ? d.proc : d.efp}`);

    // Runway ID
    const idEl = document.createElement('span');
    idEl.className = 'oei-rwy-id';
    idEl.textContent = d.rwy;

    // Procedure summary
    const procEl = document.createElement('span');
    procEl.className = 'oei-rwy-proc' + (d.coChart ? ' co-chart' : '');
    if (d.coChart) {
      procEl.textContent = 'SEE CO CHART';
    } else if (d.special && d.proc) {
      // Show abbreviated: first meaningful token (CLB VIA heading)
      const abbr = d.proc.split(' ').slice(0,4).join(' ');
      procEl.textContent = abbr + (d.proc.split(' ').length > 4 ? '…' : '');
    } else {
      procEl.textContent = d.efp;
    }

    // Checkmark for selected
    const chk = document.createElement('span');
    chk.className = 'oei-rwy-check';
    chk.textContent = d.rwy === S.oeiSelectedRwy ? '✓' : '';

    row.appendChild(idEl);
    row.appendChild(procEl);
    row.appendChild(chk);
    row.addEventListener('click', () => selectOeiRwy(d.rwy));
    row.addEventListener('pointerdown', e => {
      if (e.pointerType === 'pen') { e.preventDefault(); selectOeiRwy(d.rwy); }
    });
    list.appendChild(row);
  });

  overlay.classList.add('open');
}

function closeOeiPicker(e) {
  if (e && e.target !== document.getElementById('oeiOverlay')) return;
  document.getElementById('oeiOverlay').classList.remove('open');
}

function selectOeiRwy(rwy) {
  S.oeiSelectedRwy = rwy;
  saveFlight();
  document.getElementById('oeiOverlay').classList.remove('open');
  renderNote();
}

// ── Descent Airport Picker ────────────────────────────────────────────────
// Shows all airports on the release EXCEPT the ORIG airport.
// Crew can select any of them as the active arrival airport for the descent
// status row — useful when the planned destination changes (diversion).
function openDescentAptPicker() {
  const overlay = document.getElementById('descentAptOverlay');
  const list    = document.getElementById('descentAptList');
  if (!overlay || !list) return;

  const origIcao = (S.origIcao || '').toUpperCase();
  const current  = (S.descentAptIcao || S.destIcao || '').toUpperCase();

  // Build candidate list: all airports except ORIG, in release order
  const candidates = getAllAirports().filter(a => a.icao !== origIcao);
  if (!candidates.length) return;

  list.innerHTML = '';
  candidates.forEach(apt => {
    const icao = apt.icao;
    const isSelected = icao === current;

    // Evaluate status for the color dot
    const data = airportData[icao] || {notams:'', weather:''};
    const status = evalAirport(icao, apt.eta, data.notams, data.weather, apt.wxWindow || null);
    const dotColor = {
      green:   'var(--sys-green)',
      yellow:  'var(--sys-yellow)',
      red:     'var(--sys-red)',
      unknown: 'var(--label3)',
    }[status.color] || 'var(--label3)';

    const row = document.createElement('div');
    row.className = 'oei-rwy-row' + (isSelected ? ' selected' : '');
    row.setAttribute('role', 'button');
    row.setAttribute('aria-label', `${icao} — ${apt.role}${isSelected ? ', currently selected' : ''}`);

    // Status dot
    const dot = document.createElement('div');
    dot.style.cssText = `width:10px;height:10px;border-radius:50%;flex-shrink:0;background:${dotColor}`;
    row.appendChild(dot);

    // ICAO
    const idEl = document.createElement('span');
    idEl.className = 'oei-rwy-id';
    idEl.style.minWidth = '52px';
    idEl.textContent = icao;
    row.appendChild(idEl);

    // Role label
    const roleEl = document.createElement('span');
    roleEl.className = 'oei-rwy-proc';
    roleEl.textContent = apt.role;
    row.appendChild(roleEl);

    // Checkmark
    const chk = document.createElement('span');
    chk.className = 'oei-rwy-check';
    chk.textContent = isSelected ? '✓' : '';
    row.appendChild(chk);

    row.addEventListener('click', () => selectDescentApt(icao));
    row.addEventListener('pointerdown', e => {
      if (e.pointerType === 'pen') { e.preventDefault(); selectDescentApt(icao); }
    });
    list.appendChild(row);
  });

  overlay.classList.add('open');
}

function closeDescentAptPicker(e) {
  if (e && e.target !== document.getElementById('descentAptOverlay')) return;
  document.getElementById('descentAptOverlay').classList.remove('open');
}

function selectDescentApt(icao) {
  S.descentAptIcao = icao;
  saveFlight();
  document.getElementById('descentAptOverlay').classList.remove('open');
  renderNote();
}

// Copy FCIR narrative text to clipboard
function copyFcirNarrative() {
  const pad = document.getElementById('fcirNarrativePad');
  const txt = pad ? pad.value : (S.fcirNarrative || '');
  if (!txt.trim()) { showToast('info', 'Narrative is empty'); return; }
  navigator.clipboard.writeText(txt).then(() => {
    showToast('ok', '✓ Narrative copied');
  }).catch(() => {
    showToast('err', 'Copy failed — select text manually');
  });
}

// Copy note
function copyNote() {
  const body = document.getElementById('noteBody');
  const txt = body.innerText||body.textContent;
  navigator.clipboard.writeText(txt).then(() => {
    const btn = document.querySelector('.icon-btn[onclick="copyNote()"]');
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12l5 5L20 7"/></svg>';
    btn.style.color = 'var(--sys-green)';
    setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; }, 1600);
  });
}

