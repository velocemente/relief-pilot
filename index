// ── ENROUTE PHASE ─────────────────────────────────────────────────────────
function renderEnroutePhase() {
  // Helper: add minutes to a HHMM string, return HHMM
  const addMins = (hhmm, mins) => {
    if (!hhmm || hhmm.length !== 4) return null;
    const base = parseInt(hhmm.slice(0,2))*60 + parseInt(hhmm.slice(2,4));
    const total = (base + mins + 1440*10) % 1440;
    return String(Math.floor(total/60)).padStart(2,'0') + String(total%60).padStart(2,'0');
  };
  const fmtZ = t => t ? t + 'Z' : '——';

  const offZ = (S.offZ || '').replace(/\D/g,'').slice(0,4);
  const hasOff = offZ.length === 4;

  // Calculated times (only when OFF entered)
  const eentZ = (hasOff && S.etopsEntryMins != null)
    ? addMins(offZ, S.etopsEntryMins) : null;
  const porZ  = (hasOff && S.porOffsetMins != null)
    ? addMins(offZ, S.porOffsetMins) : null;
  const rdaZ  = porZ ? addMins(porZ, -120) : null;  // 2 hrs prior to POR

  // CO RPT schedule: every 4 hrs from OFF, but suppress if within 2–3 hrs of POR
  // Rule: report at OFF+4h, OFF+8h, etc.  Skip any that fall within porZ-3h … porZ-2h window (replaced by POR report)
  const coRpts = (() => {
    if (!hasOff) return [];
    const rpts = [];
    for (let i = 1; i <= 10; i++) {
      const mins = i * 240;
      const t = addMins(offZ, mins);
      if (!t) break;
      const tMin = parseInt(t.slice(0,2))*60 + parseInt(t.slice(2,4));
      // Check overlap with POR window (2–3 hrs before POR)
      if (porZ) {
        const pMin = parseInt(porZ.slice(0,2))*60 + parseInt(porZ.slice(2,4));
        const overlap2 = ((pMin - 120 - tMin + 1440) % 1440);
        const overlap3 = ((pMin - 180 - tMin + 1440) % 1440);
        // suppressed if this report falls in the [POR-3h, POR-2h] window
        // i.e. it's AFTER POR-3h and AT-OR-BEFORE POR-2h
        const afterMinus3 = overlap3 >= 1440 - 30 || overlap3 <= 30; // within 30 min of boundary
        const afterMinus3b = ((tMin - (pMin - 180) + 1440) % 1440) <= 60;
        const beforeMinus2 = ((pMin - 120 - tMin + 1440) % 1440) >= 0 &&
                             ((pMin - 120 - tMin + 1440) % 1440) <= 1440 - 1;
        // Simpler: suppress if (tMin is within [porMin-180, porMin-120] window
        const diff = (tMin - (pMin - 180) + 1440) % 1440;
        if (diff >= 0 && diff <= 60) {
          rpts.push({ t, suppressed: true, reason: 'overlaps POR window' });
          continue;
        }
      }
      // Stop generating past ETA dest
      if (S.etaDest && S.etaDest.length === 4) {
        const etaMin = parseInt(S.etaDest.slice(0,2))*60 + parseInt(S.etaDest.slice(2,4));
        const diff = (parseInt(t.slice(0,2))*60 + parseInt(t.slice(2,4)) - parseInt(offZ.slice(0,2))*60 - parseInt(offZ.slice(2,4)) + 1440) % 1440;
        const ete  = (etaMin - parseInt(offZ.slice(0,2))*60 - parseInt(offZ.slice(2,4)) + 1440) % 1440;
        if (diff > ete + 30) break;
      }
      rpts.push({ t, suppressed: false });
    }
    return rpts;
  })();

  let h = '';
  h += `<div class="subcard">`;
  h += `<div class="subcard-header">Enroute</div>`;
  h += `<div class="subcard-body">`;
  h += `<div class="enroute-split">`;
  h += `<div class="enroute-times-col">`;

  // OFF time entry
  h += `<div class="data-table data-table-lg">`;
  h += `<div class="data-row"><span class="data-label">OFF</span><span class="data-value">${ev('offZ', offZ ? offZ+'Z' : '____Z')}</span></div>`;
  h += `</div>`;

  if (hasOff) {
    // ── E.ENT (ETOPS entry — only on ETOPS flights) ──
    if (eentZ) {
      h += `<div class="enroute-row">`;
      h += `<span class="enroute-label">E.ENT</span>`;
      h += `<span class="enroute-value">${eentZ}Z</span>`;
      if (S.etopsEntry) h += `<span class="enroute-sub">+${esc(S.etopsEntry)}</span>`;
      h += `</div>`;
    }

    // ── RDA + POR (only on RDA/redispatch flights) ──
    // Order: RDA first (single time, 2 hrs before POR), then POR (time + MINF)
    if (rdaZ && porZ && S.porWpt) {
      // RDA — single point in time, NOT a window
      h += `<div class="enroute-row">`;
      h += `<span class="enroute-label">RDA</span>`;
      h += `<span class="enroute-value">${rdaZ}Z</span>`;
      h += `</div>`;

      // POR — waypoint, time, and minimum fuel required at that point
      h += `<div class="enroute-row" style="align-items:flex-start;padding-top:10px;padding-bottom:10px">`;
      h += `<span class="enroute-label" style="padding-top:1px">POR</span>`;
      h += `<div style="display:flex;flex-direction:column;gap:2px">`;
      h += `<span class="enroute-value">${esc(S.porWpt)}  ${porZ}Z</span>`;
      if (S.porMinf) {
        h += `<span style="font-size:13px;font-family:var(--font-mono);color:var(--label2)">MINF&nbsp;${esc(S.porMinf)}</span>`;
      }
      h += `</div>`;
      h += `</div>`;
    }

    // CO RPT schedule
    if (coRpts.length) {
      h += `<div class="enroute-row" style="align-items:flex-start;padding-top:var(--sp2);padding-bottom:var(--sp2)">`;
      h += `<span class="enroute-label" style="padding-top:2px">CO RPT</span>`;
      h += `<div style="display:flex;flex-direction:column;gap:3px">`;
      coRpts.forEach((r, i) => {
        if (r.suppressed) {
          h += `<div style="display:flex;flex-direction:column;gap:1px">`;
          h += `<span class="enroute-value dim" style="text-decoration:line-through">${r.t}Z</span>`;
          h += `<span style="font-size:11px;color:var(--label3)">POR report covers this window</span>`;
          h += `</div>`;
        } else {
          h += `<span class="enroute-value">${r.t}Z</span>`;
        }
      });
      h += `</div></div>`;
    }
  } else {
    h += `<div style="padding:var(--sp3) 0;font-size:15px;color:var(--label3)">Enter OFF time to calculate enroute events.</div>`;
  }

  h += `</div>`; // enroute-times-col
  // ── Scratchpad column ──
  h += `<div class="enroute-scratch-col">`;
  h += `<div class="enroute-scratch-label">Scratchpad</div>`;
  h += `<textarea class="enroute-scratchpad" id="enrouteScratchPad" placeholder="Notes, drawings, calculations…" aria-label="Enroute scratchpad"></textarea>`;
  h += `</div>`; // enroute-scratch-col
  h += `</div>`; // enroute-split
  h += `</div></div>`; // subcard-body + subcard
  h += renderFcirSubcard();
  return h;
}

// ── DESCENT PHASE ─────────────────────────────────────────────────────────
function renderDescentPhase() {
  let h = '';

  // ── Arrival Airport Status row ────────────────────────────────────────────
  // The selected airport defaults to destIcao but crew can tap to change it
  // to any non-ORIG airport on the release (useful for diversions).
  const descentIcao = (S.descentAptIcao || S.destIcao || '').toUpperCase();
  const dsApt = getAllAirports().find(a => a.icao === descentIcao);
  const dsEta  = dsApt ? dsApt.eta : S.etaDest;
  const dsWxWin = dsApt ? (dsApt.wxWindow || null) : null;
  const dsData = airportData[descentIcao] || {notams:'', weather:''};
  const dsStatus = descentIcao
    ? evalAirport(descentIcao, dsEta, dsData.notams, dsData.weather, dsWxWin)
    : {color:'unknown', issues:[]};

  // Build color dot
  const dsDotColor = {
    green:   'var(--sys-green)',
    yellow:  'var(--sys-yellow)',
    red:     'var(--sys-red)',
    unknown: 'var(--label3)',
  }[dsStatus.color] || 'var(--label3)';

  // Build concise issue tags (same logic as briefing card status lines)
  const dsRedTags=[], dsYelTags=[];
  dsStatus.issues.forEach(i => {
    const tag = issueTag(i.text);
    if (i.level==='red') dsRedTags.push(tag);
    else if (i.level==='yellow') dsYelTags.push(tag);
  });
  const dsUR=[...new Set(dsRedTags)], dsUY=[...new Set(dsYelTags)];
  let dsReason = '';
  if (dsUR.length) dsReason += `<span style="color:var(--sys-red);font-weight:600;font-size:13px">${dsUR.join('/')}</span>`;
  if (dsUY.length) dsReason += (dsReason?' ':'') + `<span style="color:var(--sys-yellow);font-weight:600;font-size:13px">${dsUY.join('/')}</span>`;

  // Tappable ICAO label — opens airport picker
  const dsIcaoLabel = descentIcao
    ? `<span style="font-family:var(--font-mono);font-size:15px;font-weight:700;color:var(--tint);text-decoration:underline dotted;text-underline-offset:3px;cursor:pointer"
         onclick="openDescentAptPicker()"
         onpointerdown="if(event.pointerType==='pen'){event.preventDefault();openDescentAptPicker()}"
         role="button" aria-label="Change arrival airport">${esc(descentIcao)}</span>`
    : `<span style="color:var(--label3);cursor:pointer" onclick="openDescentAptPicker()">Select airport</span>`;

  h += `<div class="subcard">`;
  h += `<div class="subcard-header">Arrival</div>`;
