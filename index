// Airport status note lines (ORIG → DEST → ALTS, using currentEta from altData)
function buildAptStatusLines() {
  const lines = [];
  const orig = (S.origIcao||'').toUpperCase();
  const dest = (S.destIcao||'').toUpperCase();

  // Build ordered list: ORIG first (no ETA), DEST second, then alternates
  const order = [];
  if (orig) order.push({icao:orig, role:'ORIG', eta:null});
  if (dest) order.push({icao:dest, role:'DEST', eta:S.etaDest});
  (S.altData||[]).forEach(a => {
    if (a.icao !== orig && a.icao !== dest) {
      order.push({icao:a.icao, role:a.role, eta:a.currentEta, wxWindow:a.wxWindow||null});
    }
  });

  order.forEach(apt => {
    const data = airportData[apt.icao] || {notams:'',weather:''};
    const status = evalAirport(apt.icao, apt.eta, data.notams, data.weather, apt.wxWindow);
    if (status.color === 'unknown') return;
    const cls = {green:'green',yellow:'yellow',red:'red'}[status.color]||'';

    const redTags=[], yelTags=[];
    status.issues.forEach(i => {
      const tag = issueTag(i.text);
      if (i.level==='red') redTags.push(tag); else if(i.level==='yellow') yelTags.push(tag);
    });
    const uR=[...new Set(redTags)], uY=[...new Set(yelTags)];

    let reason = '';
    if (uR.length) reason += `<span style="color:var(--sys-red);font-weight:600">${uR.join('/')}</span>`;
    if (uY.length) reason += (reason?' ':'') + `<span style="color:var(--sys-yellow);font-weight:600">${uY.join('/')}</span>`;

    const label = status.color === 'green'
      ? `<span class="apt-dot ${cls}"></span> <span>${apt.icao}</span>`
      : `<span class="apt-dot ${cls}"></span> <span>${apt.icao}</span><span style="color:var(--label3);margin:0 4px">·</span>${reason}`;
    lines.push(label);
  });
  return lines;
}

function issueTag(txt) {
  txt = txt.replace(/^[🔴⚠✓ℹ🟢🟡⚪]+\s*/,'');
  if (/CURFEW|NOISE/i.test(txt)) return 'CURFEW';
  if (/CEILING|VIS|CAVOK|TEMPO|BECMG|PROB|TS\b|FZRA|FOG|WX|WIND|PRECIP/i.test(txt)) return 'WX';
  if (/CLSD|U\/S|ILS|NAVAID|TWY|RWY|VOLCANIC/i.test(txt)) return 'NOTAM';
  return txt.substring(0,18);
}

// ── Curfew evaluation engine ─────────────────────────────────────────────
// Parses structured curfew text from STATION COMPANY NOTAMS into time windows
// and checks proximity to ETA. Returns { color, minsDelta, windows } per airport.
//
// color: 'none'   — no curfew data
//        'green'  — curfew exists but ETA >120 min clear of all windows
//        'yellow' — ETA 90–120 min from a window boundary
//        'red'    — ETA within 90 min of (or inside) a window
//
// "In effect during arrival window" = ETA falls inside a curfew window,
// OR the nearest window boundary is within 120 min of ETA.

function parseCurfewWindows(curfewText) {
  // Extract all HHMM–HHMM pairs from the curfew text.
  // Handles: "1800–2359Z", "1200Z-1900Z", "2200Z - 2220Z"
  const windows = [];
  const re = /(\d{4})Z?\s*[-–]\s*(\d{4})Z?/g;
  let m;
  while ((m = re.exec(curfewText)) !== null) {
    const s = parseInt(m[1].slice(0,2))*60 + parseInt(m[1].slice(2,4));
    const e = parseInt(m[2].slice(0,2))*60 + parseInt(m[2].slice(2,4));
    // e < s means window crosses midnight (e.g. 2200–0200)
    windows.push({ start: s, end: e, crosses: e < s });
  }
  return windows;
}

// Returns minutes from ETA to the nearest curfew window boundary (or 0 if inside).
// Positive = ETA is outside; negative/0 = ETA is inside or at boundary.
function curfewDeltaMins(windows, etaMin) {
  if (etaMin === null || !windows.length) return null;
  let closest = Infinity;
  for (const w of windows) {
    // Check if ETA is inside this window
    let inside;
    if (!w.crosses) {
      inside = etaMin >= w.start && etaMin <= w.end;
    } else {
      inside = etaMin >= w.start || etaMin <= w.end;
    }
    if (inside) return 0; // ETA is inside a curfew — worst case
    // Distance to start and end
    const ds = Math.min(Math.abs(etaMin - w.start), 1440 - Math.abs(etaMin - w.start));
    const de = Math.min(Math.abs(etaMin - w.end),   1440 - Math.abs(etaMin - w.end));
    closest = Math.min(closest, ds, de);
  }
  return closest;
}

function evalCurfew(icao, etaZ) {
  const apt = airportData[icao] || {};
  const curfewText = apt.curfew || '';
  if (!curfewText.trim()) return { color: 'none', windows: [], detail: '' };

  const windows = parseCurfewWindows(curfewText);
  if (!windows.length) return { color: 'none', windows: [], detail: curfewText };

  const etaMin = pZM(etaZ);
  const delta  = curfewDeltaMins(windows, etaMin);

  let color;
  if (delta === null) {
    color = 'green'; // no ETA known — show curfew as advisory (green)
  } else if (delta === 0) {
    color = 'red';   // ETA inside a curfew window
  } else if (delta <= 90) {
    color = 'red';
  } else if (delta <= 120) {
    color = 'yellow';
  } else {
    color = 'green';
  }

  return { color, windows, delta, detail: curfewText };
}

function buildCurfewEntries() {
  // Used by briefing card — only include airports where curfew is in effect
  // (ETA inside or within 120 min of a window, i.e. color != 'none' && color != 'green'... 
  //  actually show ALL curfews detected within 120 min so crew is aware)
  const entries = [];
  const orig = (S.origIcao||'').toUpperCase();
  const dest = (S.destIcao||'').toUpperCase();
  const icaos = [];
  if (orig) icaos.push(orig);
  if (dest && dest !== orig) icaos.push(dest);
  (S.altData||[]).forEach(a => { if (a.icao !== orig && a.icao !== dest) icaos.push(a.icao); });

  icaos.forEach(icao => {
    const apt = getAllAirports().find(a => a.icao === icao);
    const etaZ = apt ? apt.eta : null;

    // 1. Structured curfew field from STATION COMPANY NOTAMS parser
    const cf = evalCurfew(icao, etaZ);
    if (cf.color !== 'none') {
      // Only show on briefing card if within 120-min window (yellow or red)
      if (cf.color === 'yellow' || cf.color === 'red') {
        const lines = cf.detail.trim().split('\n').filter(Boolean);
        const summary = lines.length > 2
          ? lines.slice(0, 2).join(' / ') + ` +${lines.length - 2} more`
          : lines.join(' / ');
        entries.push({ icao, hours: summary, color: cf.color, detail: cf.detail });
      }
      return;
    }

    // 2. Fallback: scan user-entered notams field for curfew keywords
    const n = ((airportData[icao]||{}).notams||'').toUpperCase();
    if (!n || !/CURFEW|NOISE\s+ABATEMENT.*CLSD|LDG\s+CLSD|TKOF\s+CLSD|NIGHT\s+RESTRIC/.test(n)) return;
    let hours = '';
    const hm = n.match(/(\d{4})Z?\s*[-–TO]+\s*(\d{4})Z?/);
    if (hm) hours = hm[1] + '–' + hm[2] + 'Z';
    else { const hm2 = n.match(/(\d{2}:\d{2})\s*[-–]\s*(\d{2}:\d{2})/); if (hm2) hours = hm2[1] + '–' + hm2[2]; }
    entries.push({ icao, hours: hours || 'See NOTAM', color: 'yellow' });
  });
  return entries;
}

