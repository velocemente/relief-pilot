// ═══════════════════════════════════════════════════════
//  OFP PARSER
// ═══════════════════════════════════════════════════════
function fuelK(raw) {
  const n = parseFloat((raw||'').replace(/[^0-9.]/g,''));
  return isNaN(n) ? '' : (n/1000).toFixed(1);
}

function parseOFP() {
  const t = pdfRawText; if (!t) return;
  const MONTHS = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};
  const MON_NAMES = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];

  // ─────────────────────────────────────────────────────────
  // Helper: parse "KEYWORD ICAO/xxx ... HHMMz" from a single line
  // Atlas/Polar OFP header lines are self-contained, e.g.:
  //   ORIG VHHH/HKG HONG KONG INTL Q N22185E113549 0510Z
  //   DEST PANC/ANC ANCHORAGE TED STEVENS N61104W149599 1440Z
  //   PALT PAED/EDF ELMENDORF AFB N61151W149484 1455Z
  // Returns {icao, hhmm} or null
  function parseAptLine(keyword) {
    // Match keyword at start of line, then ICAO/xxx, then anything, then HHMMz at end
    const re = new RegExp(
      '^' + keyword + '\\s+([A-Z]{4})\\/\\S+[^\\n]*?(\\d{4})Z\\s*$',
      'm'
    );
    const m = t.match(re);
    if (!m) return null;
    return { icao: m[1], hhmm: m[2] };
  }

  // ── Flight ID
  let fltNum = '';
  const fltHeaderM = t.match(/\b([A-Z]{2,3}\d{3,5})\s*\/\s*(\d{2})\b/);
  if (fltHeaderM) {
    fltNum = fltHeaderM[1] + '/' + fltHeaderM[2];
  } else {
    const fltM = t.match(/[.\s]([A-Z]{2,3}\d{3,5})\s*\/[\x00-\x1f]/);
    if (fltM) fltNum = fltM[1];
    if (!fltNum) { const m = t.match(/\(FPL-([A-Z]{2,3}\d{3,5})-/); if(m) fltNum = m[1]; }
  }

  // ── Aircraft type
  let acftType = '';
  const fplA = t.match(/\(FPL-[A-Z0-9]+-[A-Z]+\s*\n?-([A-Z0-9]{2,4})\/[A-Z]/);
  if (fplA) acftType = fplA[1];

  // ── Date from OFP header line "06 MAR 26" or DOF/260306
  let dateStr = '', flightDateObj = null;
  const dofM = t.match(/DOF\/(\d{2})(\d{2})(\d{2})/i);
  if (dofM) {
    // DOF/YYMMDD
    const yy = 2000 + parseInt(dofM[1]);
    const mm = parseInt(dofM[2]) - 1;
    const dd = parseInt(dofM[3]);
    flightDateObj = new Date(Date.UTC(yy, mm, dd));
    dateStr = String(dd).padStart(2,'0') + ' ' + MON_NAMES[mm] + ' ' + String(yy).slice(-2);
  }
  if (!flightDateObj) {
    const pd = t.match(/(\d{1,2})\s+(JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)\s+(\d{2,4})/i);
    if (pd) {
      let yy = parseInt(pd[3]); if (yy < 100) yy += 2000;
      const mm = MONTHS[pd[2].toUpperCase()];
      const dd = parseInt(pd[1]);
      flightDateObj = new Date(Date.UTC(yy, mm, dd));
      dateStr = String(dd).padStart(2,'0') + ' ' + pd[2].toUpperCase() + ' ' + String(yy).slice(-2);
    }
  }
  window._flightDateISO = flightDateObj ? flightDateObj.toISOString().slice(0,10) : '';

  // ── ETOPS — only present on ETOPS-approved twin-engine flights
  // ETOPS ENTRY: in OFP header as "ETOPS Entry HH:MM" (elapsed time to ETOPS airspace entry)
  // ETOPS spec:  in CFS header as "Critical Fuel Scenario   ETOPS  60/180"
  //              threshold/MDT — e.g. 60 = ETOPS threshold, 180 = max diversion time
  const etopsEntryM = t.match(/ETOPS\s+Entry\s+(\d{1,2}:\d{2})/i);
  const etopsEntry  = etopsEntryM ? etopsEntryM[1] : '';
  const etopsSpecM  = t.match(/Critical Fuel Scenario\s+ETOPS\s+(\d{2,3}\/\d{2,3})/i);
  const etopsSpec   = etopsSpecM  ? etopsSpecM[1]  : '';

  // ── ETOPS entry elapsed minutes (for enroute E.ENT time calc) ──
  // etopsEntry is "HH:MM" elapsed; convert to total minutes
  const etopsEntryMins = (() => {
    if (!etopsEntry) return null;
    const [hh, mm] = etopsEntry.split(':').map(Number);
    return hh * 60 + mm;
  })();

  // ── POR (Point of Redispatch) waypoint + elapsed time ──
  // Header line: "DP(POR): 60N040W 06.52"  or  route line "(POR) AT N60W040"
  // Elapsed format HH.MM (not HH:MM)
  const porHeaderM = t.match(/DP\(POR\):\s*(\S+)\s+(\d{1,2})\.(\d{2})/i);
  const porRouteM  = !porHeaderM && t.match(/\(POR\)\s+AT\s+(\S+)/i);
  const porWpt     = porHeaderM ? porHeaderM[1].replace(/^(\d{2})([NS])(\d{3})([EW])$/, '$2$1$4$3')  // 60N040W → N60W040
                   : porRouteM  ? porRouteM[1] : '';
  const porOffsetMins = (() => {
    if (porHeaderM) {
      const hh = parseInt(porHeaderM[2]), mm = parseInt(porHeaderM[3]);
      return hh * 60 + mm;
    }
    // Fallback: find elapsed time from route table row immediately after "(POR) AT" line
    const porRouteIdx = t.indexOf('(POR) AT ');
    if (porRouteIdx === -1) return null;
    const after = t.slice(porRouteIdx, porRouteIdx + 400);
    const elapsedM = after.match(/\b(\d{2})\.(\d{2})\s+F\d{3}/);
    return elapsedM ? parseInt(elapsedM[1]) * 60 + parseInt(elapsedM[2]) : null;
  })();

  // ── ALT1 fuel (destination alternate fuel from fuel summary) ──
  // Format: "ALT1 (004016 00.23 0092)" or "ALT1 004016 00.23 0092"
  const alt1M    = t.match(/^ALT1\s+\(?\s*(\d{5,7})/m);
  const alt1Fuel = alt1M ? String(parseInt(alt1M[1])) : '';

  // ── REMF at destination (first REMF line in fuel summary, leftmost column) ──
  // Format: "REMF 016626 01.45 .... 016626 01.45 020863 02.11"
  const remfM    = t.match(/^REMF\s+(\d{5,7})/m);
  const destRemf = remfM ? String(parseInt(remfM[1])) : '';

  // ── POR MINF (minimum fuel required at the Point of Redispatch) ──
  // RDA OFPs have a two-column MINF line:
  //   MINF  087301  11.39  ....  030679  04.36  083572  11.04
  //         ↑ full trip MINF   ↑ POR MINF (post-POR segment)
  // The POR MINF is the minimum fuel the aircraft must have ON BOARD at the POR
  // to continue to the destination under the redispatch plan.
  // Non-RDA OFPs have only a single MINF column — porMinf will be '' in that case.
  const porMinfM = t.match(/^MINF\s+\d{5,7}\s+[\d.]+\s+\.+\s+(\d{5,7})/m);
  const porMinf  = porMinfM ? String(parseInt(porMinfM[1])) : '';


  // Format: ORIG VHHH/HKG HONG KONG INTL Q N22185E113549 0510Z
  const origLine = parseAptLine('ORIG');
  const origIcao  = origLine ? origLine.icao : '';
  const offFromOFP = origLine ? origLine.hhmm : '';

  // ── DEST line → destination ICAO and ETA (authoritative from OFP header line)
  // Format: DEST PANC/ANC ANCHORAGE TED STEVENS N61104W149599 1440Z
  const destLine = parseAptLine('DEST');
  const destIcao = destLine ? destLine.icao : '';
  const etaDest  = destLine ? destLine.hhmm : '';

  // ── Dest ETA offset from OFP OFF time (used when pilot edits OUT time)
  // This is the OFP-planned time from engines-off to DEST arrival,
  // including taxi/startup — more accurate than TRIP flight time alone.
  const ofpOffMinCalc = offFromOFP.length === 4
    ? parseInt(offFromOFP.slice(0,2))*60 + parseInt(offFromOFP.slice(2,4))
    : null;
  let destEtaOffsetMins = null;
  if (etaDest.length === 4 && ofpOffMinCalc !== null) {
    const eMin = parseInt(etaDest.slice(0,2))*60 + parseInt(etaDest.slice(2,4));
    let off = eMin - ofpOffMinCalc;
    if (off < 0) off += 1440; // midnight crossing
    destEtaOffsetMins = off;
  }

  // ── Trip minutes (flight time only, from TRIP field — kept for reference)
  const tripM = t.match(/TRIP\s+\d+\s+(\d{2})\.(\d{2})/);
  const tripMinutes = tripM ? parseInt(tripM[1])*60 + parseInt(tripM[2]) : null;

  // ── Alternates — each on its own header line, same format
  // Only named alt types; NOT CFS (those are en-route diversion scenarios, not release airports)
  const ALT_PATTERNS = [
    { key:'PALT', role:'DEST ALT'     },
    { key:'SALT', role:'DEST ALT'     },
    { key:'RALT', role:'EN ROUTE ALT' },
    { key:'RAPT', role:'EN ROUTE ALT' },
    { key:'TALT', role:'TKOF ALT'     },
  ];

  // OFF time in minutes for offset calculation
  const ofpOffMin = ofpOffMinCalc;

  const altData = [];
  ALT_PATTERNS.forEach(({ key, role }) => {
    const line = parseAptLine(key);
    if (!line) return;
    const { icao, hhmm: ofpEta } = line;
    if (altData.find(a => a.icao === icao)) return; // deduplicate

    // Compute offset in minutes from OFP departure time — used to recalc when OUT is edited
    let ofpOffsetMins = null;
    if (ofpEta.length === 4 && ofpOffMin !== null) {
      const etaMin = parseInt(ofpEta.slice(0,2))*60 + parseInt(ofpEta.slice(2,4));
      let offset = etaMin - ofpOffMin;
      if (offset < 0) offset += 1440; // handle midnight crossing
      ofpOffsetMins = offset;
    } else if (tripMinutes !== null) {
