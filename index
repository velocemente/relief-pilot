<script>
'use strict';

// ═══════════════════════════════════════════════════════
//  VERSION
// ═══════════════════════════════════════════════════════
const APP_VERSION = '1.9.0-dev-r2';

// ═══════════════════════════════════════════════════════
//  PER-USER ISOLATION — each browser/device gets its own
//  data namespace so shared iPads don't bleed data between
//  crew members. UID is generated once per browser profile
//  and stored in localStorage under a fixed key.
// ═══════════════════════════════════════════════════════
const _UID = (() => {
  try {
    let uid = localStorage.getItem('rp_uid');
    if (!uid) {
      // crypto.randomUUID() available on modern iOS/Safari; fallback to Math.random
      uid = (typeof crypto !== 'undefined' && crypto.randomUUID)
        ? crypto.randomUUID()
        : 'u' + Date.now().toString(36) + Math.random().toString(36).slice(2);
      localStorage.setItem('rp_uid', uid);
    }
    return uid;
  } catch(e) { return 'default'; }
})();
// Namespaced storage keys — all flight data is private to this UID
const _KEY_FLIGHTS = 'rp_flights_' + _UID;
const _KEY_THEME   = 'rp_theme_'   + _UID;

// ═══════════════════════════════════════════════════════
//  THEME — follows system, or manual override
// ═══════════════════════════════════════════════════════
let _themeMode = 'auto';
try { _themeMode = localStorage.getItem(_KEY_THEME) || 'auto'; } catch(e) {}

function setTheme(mode) {
  _themeMode = mode;
  try { localStorage.setItem(_KEY_THEME, mode); } catch(e) {}
  const pDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const effective = mode === 'auto' ? (pDark ? 'dark' : 'light') : mode;
  // CSS color-scheme property drives system semantic colors
  document.documentElement.style.colorScheme = mode === 'auto' ? 'light dark' : mode;
  // Update segmented control
  document.querySelectorAll('.seg-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.theme === mode);
  });
}
(function() {
  setTheme(_themeMode);
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (_themeMode === 'auto') setTheme('auto');
  });
})();

// ═══════════════════════════════════════════════════════
//  NAVIGATION — push / pop / sheet stack
//  Mirrors iOS UINavigationController behavior
// ═══════════════════════════════════════════════════════
let _navStack = ['screen-flights'];
let _sheetOpen = null;

function push(screenId) {
  // Dim current top
  const cur = document.getElementById(_navStack[_navStack.length - 1]);
  if (cur) { cur.classList.remove('is-root', 'is-active'); cur.classList.add('is-behind'); }

  _navStack.push(screenId);
  const next = document.getElementById(screenId);
  if (next) {
    next.classList.remove('is-behind');
    // Force reflow for transition
    void next.offsetWidth;
    next.classList.add('is-active');
  }

  if (screenId === 'screen-flights') renderFlightList();
  if (screenId === 'screen-flight') {
    // Clear OFP panel so loadOFPPanel re-renders for the new flight
    const ofpC = document.getElementById('ofpViewerContainer');
    if (ofpC) ofpC.innerHTML = '';
    const ofpCtr = document.getElementById('ofpPageCounter');
    if (ofpCtr) ofpCtr.textContent = '';
    renderNote(); buildAirportCards(); buildAltRouteCards(); switchFlightTab('note', false);
  }
  if (screenId === 'screen-import') {
    document.getElementById('importToast').style.display = 'none';
    document.getElementById('manualText').value = '';
  }
}

// goToImport: always ensure screen-flights is in the stack before screen-import,
// so that back from note → flights works regardless of entry point.
function goToImport() {
  if (!_navStack.includes('screen-flights')) push('screen-flights');
  push('screen-import');
}

// popToFlights: back button from screen-note always lands on screen-flights.
// If flights isn't in the stack (e.g. deep-link entry), insert it cleanly.
function popToFlights() {
  // Pop everything above screen-flights, or pop once and ensure flights is shown
  while (_navStack.length > 1 && _navStack[_navStack.length - 1] !== 'screen-flights') {
    const top = _navStack.pop();
    const topEl = document.getElementById(top);
    if (topEl) topEl.classList.remove('is-active', 'is-behind');
  }
  // If we never hit flights, push it now
  if (_navStack[_navStack.length - 1] !== 'screen-flights') {
    push('screen-flights');
    return;
  }
  // Activate flights
  const flightsEl = document.getElementById('screen-flights');
  if (flightsEl) { flightsEl.classList.remove('is-behind'); flightsEl.classList.add('is-active'); }
  renderFlightList();
}

function pop() {
  if (_navStack.length <= 1) return;
  const top = _navStack.pop();
  const topEl = document.getElementById(top);
  if (topEl) { topEl.classList.remove('is-active'); }

  const prev = _navStack[_navStack.length - 1];
  const prevEl = document.getElementById(prev);
  if (prevEl) {
    prevEl.classList.remove('is-behind');
    prevEl.classList.add(prev === 'screen-flights' ? 'is-root' : 'is-active');
  }
  // Refresh flight list whenever we return to flights or home
  if (prev === 'screen-home' || prev === 'screen-flights') renderFlightList();
}


// ── Flight tab switcher ──────────────────────────────────────────────────
// tabs: 'note' | 'airports' | 'ofp' | 'alternates'
// render=true (default): trigger data build for the selected tab
let _activeFlightTab = 'note';

function switchFlightTab(tab, render = true) {
  _activeFlightTab = tab;

  // Update tab button active states
  ['note','airports','ofp','alternates'].forEach(t => {
    const btn = document.getElementById('ftab-' + t);
    if (btn) btn.classList.toggle('active', t === tab);
  });

  // Show/hide panels
  ['note','airports','ofp','alternates'].forEach(t => {
    const panel = document.getElementById('fpanel-' + t);
    if (panel) panel.classList.toggle('active', t === tab);
  });

  // Trigger data load for the activated tab
  if (!render) return;
  if (tab === 'airports')  buildAirportCards();
  if (tab === 'alternates') buildAltRouteCards();
  if (tab === 'ofp')        loadOFPPanel();
}

// Populate the OFP viewer panel (was openOFPView)
function loadOFPPanel() {
  const container = document.getElementById('ofpViewerContainer');
  const counter   = document.getElementById('ofpPageCounter');
  if (!container) return;
  // Skip re-render only when PDF canvas pages are already present.
  // A stale "Loading…" placeholder, error message, or raw-text fallback must
  // not block a fresh render — so check for an actual <canvas>, not just any child.
  if (container.querySelector('canvas')) return;
  container.innerHTML = '';
  if (counter) counter.textContent = '';

  if (pdfArrayBuffer) {
    _pdfDocProxy = null;
    container.innerHTML = '<div style="color:var(--label2);text-align:center;padding:32px;font-size:15px">Loading PDF…</div>';
    loadPdfJs().then(() => {
      pdfjsLib.getDocument({data: new Uint8Array(pdfArrayBuffer.slice(0))}).promise.then(pdf => {
        _pdfDocProxy = pdf;
        container.innerHTML = '';
        const total = pdf.numPages;
        if (counter) counter.textContent = `${total} pages`;
        const dpr = window.devicePixelRatio || 1;
        const renderPage = (n) => {
          pdf.getPage(n).then(pg => {
            const viewerW = container.clientWidth || (window.innerWidth - 32);
            const vp0 = pg.getViewport({scale: 1});
            const vp  = pg.getViewport({scale: (viewerW / vp0.width) * dpr});
            const wrap = document.createElement('div');
            wrap.style.cssText = 'position:relative;margin:0 auto 16px;max-width:100%';
            const canvas = document.createElement('canvas');
            canvas.width  = Math.max(1, Math.round(vp.width));
            canvas.height = Math.max(1, Math.round(vp.height));
            canvas.style.cssText = 'display:block;width:100%;height:auto;border-radius:4px;box-shadow:0 1px 6px rgba(0,0,0,.22)';
            wrap.appendChild(canvas);
            const lbl = document.createElement('div');
            lbl.textContent = `${n} / ${total}`;
            lbl.style.cssText = 'position:absolute;bottom:8px;right:10px;font-size:11px;font-family:var(--font-mono);color:rgba(120,120,128,0.9);pointer-events:none;background:var(--sys-bg2);padding:2px 6px;border-radius:4px;';
            wrap.appendChild(lbl);
            container.appendChild(wrap);
            pg.render({canvasContext: canvas.getContext('2d'), viewport: vp});
            if (n < total) renderPage(n + 1);
          });
        };
        // Defer one animation frame so the panel (display:flex applied by
        // switchFlightTab) has been laid out and container.clientWidth is valid
        requestAnimationFrame(() => renderPage(1));
      }).catch(err => {
        _pdfDocProxy = null;
        if (counter) counter.textContent = '';
        container.innerHTML = `<div class="ofp-raw" style="color:var(--sys-red);padding:var(--sp4)">PDF render error: ${esc(err.message)}</div>`;
      });
    }).catch(() => {
      container.innerHTML = '';
      if (counter) counter.textContent = '';
      const pre = document.createElement('div');
      pre.className = 'ofp-raw';
      pre.textContent = pdfRawText || 'No OFP imported yet.';
      container.appendChild(pre);
    });
  } else {
    container.innerHTML = '';
    if (counter) counter.textContent = '';
    const pre = document.createElement('div');
    pre.className = 'ofp-raw';
    pre.textContent = pdfRawText || 'No OFP imported yet.';
    container.appendChild(pre);
  }
}



// ═══════════════════════════════════════════════════════
//  APP STATE — single source of truth
// ═══════════════════════════════════════════════════════
const S = {
  fltNum:'', date:'',
  outZ:'',          // filled from OFP OFF time; editable; drives all ETA recalcs
  etaDest:'',       // ETA at DEST; recalculated when outZ changes
  origIcao:'', destIcao:'',
  // altData: [{icao, role, ofpEta, ofpOffsetMins, currentEta}]
  // ofpOffsetMins = minutes from OFP's OFF time to this alt's ETA
  // currentEta    = recalculated when outZ changes
  altData:[],
  oeiVal:'', stabTrim:'', gaFuel:'',
  // oeiData: [{rwy, efp, special, proc, coChartNote}]
  //   rwy:         e.g. "07R"  (base runway, no SHIPS suffix)
  //   efp:         "SPECIAL" | "DT H254" | "LT H235" | "RT H090" etc.
  //   special:     boolean — true if this runway has a special EFP table entry
  //   proc:        full special proc string, or '' for simple EFPs
  //   coChartNote: crew-entered text for "SEE CO CHART" runways (SPECIAL + no proc)
  oeiData:[], oeiSelectedRwy:'',
  blockFuel:'', minfFuel:'', fresFuel:'',
  // ddgItems: structured DDG/MEL array [{code, desc, tlr}]
  //   code: ATA number string e.g. "36-12-02-01"
  //   desc: full description string (may be multi-line joined)
  //   tlr:  ''|'takeoff'|'landing'|'both'  — TLR Remarks cross-reference
  ddgItems:[], melItems:'', overflightPerms:'',
  altRoutes:[],   // [{title, route, mora}] — parsed from OFP alternate route sections; crew-editable
  acftType:'', togwActual:0, togwLimit:0,
  hasPerishables:false,
  destEtaOffsetMins:null, // minutes from OFP OFF time to DEST ETA (authoritative, from OFP header lines)
  tripMinutes:null,        // flight-only trip time from TRIP field (kept for reference)
  userNotes:'',
  fcirNarrative:'',
  fcirAsap: false,
  etopsEntry:'',   // elapsed time to ETOPS airspace entry, e.g. "06:12" — from OFP header
  etopsSpec:'',    // ETOPS threshold/MDT, e.g. "60/180" — from Critical Fuel Scenario header
  etpPoints:[],    // [{name:'ETP1', lat:'N59 42.2', lon:'W036 03.6'}] — parsed from CFS block

  // ── Phase tabs & enroute ──
  activePhase:'preflight',   // 'preflight' | 'enroute' | 'descent'
  offZ:'',            // actual OFF time entered by crew (HHMM Z)
  porWpt:'',          // POR waypoint parsed from OFP, e.g. "N60W040"
  porOffsetMins:null, // OFP elapsed minutes ORIG→POR (HH.MM converted)
  porMinf:'',         // Minimum fuel required at POR (col2 of MINF line on RDA OFPs)
  etopsEntryMins:null,// OFP elapsed minutes to ETOPS entry  (HH.MM converted)

  // ── Preflight / Departure ATIS + Parking (independent of Descent) ──
  preAtisLetter:'',   // Departure ATIS identifier letter, e.g. "K"
  preAtisNotes:'',    // Departure ATIS free-text notes
  preParkingNotes:'', // Departure gate / stand free-text

  // ── Descent / Arrival ATIS + Parking (independent of Preflight) ──
  descAtisLetter:'',  // Arrival ATIS identifier letter, e.g. "K"
  descAtisNotes:'',   // Arrival ATIS free-text notes
  descParkingNotes:'',// Arrival gate / stand free-text
  descentAptIcao:'',  // Airport shown on descent status row; defaults to destIcao, crew-selectable
  enrouteScratch:'',  // enroute scratchpad (drawing + text)

  // ── Arrival fuel (parsed + carried-over) ──
  alt1Fuel:'',        // ALT1 fuel from OFP fuel summary
  destRemf:'',        // REMF at destination from OFP
};
let airportData = {};   // icao → { notams:'', weather:'' }
let pdfRawText    = '';
let pdfArrayBuffer = null;   // ArrayBuffer of original PDF — slice a fresh Uint8Array for each pdf.js call so the master is never transferred/neutered
let _pdfDocProxy  = null;    // active PDFDocumentProxy — nulled before each new load (M3)

// Recalculate DEST ETA and all alt ETAs from current outZ
// ── IMPORTANT: New flight = clean slate. No data carries between flights. ──
// resetStateForNewFlight() wipes every field so the previous flight's
// crew-entered values (ATIS, parking, notes, STAB, GA, FCIR, scratchpad)
// never bleed into a new import.
function resetStateForNewFlight() {
  Object.assign(S, {
    fltNum:'', date:'',
    outZ:'', etaDest:'',
    origIcao:'', destIcao:'',
    altData:[],
    oeiVal:'', stabTrim:'', gaFuel:'',
    oeiData:[], oeiSelectedRwy:'',
    blockFuel:'', minfFuel:'', fresFuel:'',
    ddgItems:[], melItems:'', overflightPerms:'',
    altRoutes:[], acftType:'', togwActual:0, togwLimit:0,
    hasPerishables:false,
    destEtaOffsetMins:null, tripMinutes:null,
    userNotes:'', fcirNarrative:'', fcirAsap:false,
    etopsEntry:'', etopsSpec:'', etpPoints:[],
    activePhase:'preflight',
    offZ:'', porWpt:'', porOffsetMins:null, porMinf:'', etopsEntryMins:null,
    preAtisLetter:'', preAtisNotes:'', preParkingNotes:'',
    descAtisLetter:'', descAtisNotes:'', descParkingNotes:'',
    descentAptIcao:'',
    enrouteScratch:'',
    alt1Fuel:'', destRemf:'',
  });
  airportData = {};
  pdfRawText = '';
  pdfArrayBuffer = null;
  _pdfDocProxy = null;
  _fcirActive = false;
  window._flightDateISO = '';
  clearOFPPanel();
  // Reset FCIR toggle UI
  const tog = document.getElementById('fcirToggle');
  if (tog) tog.checked = false;
  const lbl = document.getElementById('fcirLabel');
  if (lbl) lbl.classList.remove('active');
}

function recalcAllETAs() {
  if (!S.outZ || S.outZ.length !== 4) return;
  const baseMin = parseInt(S.outZ.slice(0,2))*60 + parseInt(S.outZ.slice(2,4));
  const addMin  = (base, off) => {
    const t = (base + off + 1440*4) % 1440;
    return String(Math.floor(t/60)).padStart(2,'0') + String(t%60).padStart(2,'0');
  };
  // Use OFP-derived offset (DEST ETA − ORIG OFF from OFP header) for accuracy
  // This preserves taxi/startup time that pure TRIP flight-time doesn't include
  if (S.destEtaOffsetMins !== null) {
    S.etaDest = addMin(baseMin, S.destEtaOffsetMins);
  }
  S.altData.forEach(a => {
    if (a.ofpOffsetMins !== null) {
      a.currentEta = addMin(baseMin, a.ofpOffsetMins);
    }
  });
}

// Recalculate IN time and alternate ETAs from the actual OFF (wheels-up) time.
// Uses tripMinutes (OFP ETE) for DEST, and ofpOffsetMins adjusted for taxi time
// for alternates. This keeps IN time accurate once airborne.
// offZ is actual wheels-off; tripMinutes is OFP planned flight time (no taxi).
function recalcAllETAsFromOff(offZval) {
  if (!offZval || offZval.length !== 4) return;
  const baseMin = parseInt(offZval.slice(0,2))*60 + parseInt(offZval.slice(2,4));
  const addMin  = (base, off) => {
    const t = (base + off + 1440*4) % 1440;
    return String(Math.floor(t/60)).padStart(2,'0') + String(t%60).padStart(2,'0');
  };
  // DEST: offZ + tripMinutes = actual IN estimate
  if (S.tripMinutes !== null) {
    S.etaDest = addMin(baseMin, S.tripMinutes);
  }
  // Alternates: offZ + (ofpOffsetMins − taxiApprox)
  // ofpOffsetMins was computed as altETA − origOFF (includes taxi), so for
  // airborne recalc we subtract the OFP taxi time: destEtaOffsetMins − tripMinutes
  const taxiMins = (S.destEtaOffsetMins !== null && S.tripMinutes !== null)
    ? S.destEtaOffsetMins - S.tripMinutes
    : 0;
  S.altData.forEach(a => {
    if (a.ofpOffsetMins !== null) {
      a.currentEta = addMin(baseMin, Math.max(0, a.ofpOffsetMins - taxiMins));
    }
  });
}

