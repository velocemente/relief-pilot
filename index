    copyBtn.setAttribute('aria-label', 'Copy route to clipboard');
    copyBtn.title = 'Copy route';
    copyBtn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2"/>
