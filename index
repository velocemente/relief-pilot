// ═══════════════════════════════════════════════════════
const FIELD_LABELS = {
  outZ:'OUT Time (HHMM) — updates all ETAs', etaDest:'IN Time (HHMM)',
  oeiVal:'OEI', stabTrim:'Stab Trim', fltNum:'Flight Number', date:'Date',
  blockFuel:'Block Fuel (×1000)', minfFuel:'MIN Fuel (×1000)',
  fresFuel:'FRES (×1000)', gaFuel:'GA Fuel (×1000)',
  offZ:'OFF Time (HHMM Z)',
  atisLetter:'ATIS Letter (single letter)',
  preAtisLetter:'Departure ATIS Letter',
  descAtisLetter:'Arrival ATIS Letter',
  destRemf:'REMF at Destination', alt1Fuel:'ALT 1 Fuel',
};
const NUM_FIELDS = new Set(['outZ','etaDest','offZ','destRemf','alt1Fuel']);
let _editField = null;

function openEdit(field) {
  _editField = field;
  const inp = document.getElementById('editInput');
  inp.value = (S[field]||'').replace(/Z$/,'');
  inp.inputMode = NUM_FIELDS.has(field) ? 'numeric' : 'text';
  inp.autocapitalize = NUM_FIELDS.has(field) ? 'off' : 'characters';
  document.getElementById('editLabel').textContent = FIELD_LABELS[field] || field;
  document.getElementById('editOverlay').classList.add('open');
  setTimeout(() => { inp.focus(); inp.select(); }, 60);
}

function confirmEdit() {
  if (!_editField) return;
  // Read-only detail modal (NOTAM source / curfew) — restore input, hide pre, close
  if (_editField === '__curfew__') {
    const inp = document.getElementById('editInput');
    const pre = document.getElementById('issueDetailPre');
    inp.style.display = '';   // restore input to default display
    inp.readOnly = false;
    inp.style.cssText = '';
    pre.classList.remove('active');
    pre.textContent = '';
    _editField = null;
    document.getElementById('editOverlay').classList.remove('open');
    return;
  }
  let val = document.getElementById('editInput').value.trim();
  if (NUM_FIELDS.has(_editField)) {
    val = val.replace(/\D/g,'').slice(0,4);
  }
  S[_editField] = val;

  // Editing outZ cascades DEST ETA + ALL alt ETAs (planned push time)
  if (_editField === 'outZ' && val.length === 4) {
    recalcAllETAs();
  }

  // Editing offZ (actual wheels-off) recalculates IN time using OFP ETE (tripMinutes).
  // offZ + tripMinutes = actual estimated IN time at destination.
  // All alternate ETAs also recalculate from offZ + their ofpOffsetMins offset.
  if (_editField === 'offZ' && val.length === 4) {
    recalcAllETAsFromOff(val);
  }

  cancelEdit();
  renderNote();
  saveFlight();
}

function cancelEdit(e) {
  if (e && e.target !== document.getElementById('editOverlay')) return;
  // Restore input / hide pre whenever the overlay is dismissed
  const inp = document.getElementById('editInput');
  const pre = document.getElementById('issueDetailPre');
  if (pre && pre.classList.contains('active')) {
    inp.style.display = '';
    inp.readOnly = false;
    inp.style.cssText = '';
    pre.classList.remove('active');
    pre.textContent = '';
  }
  document.getElementById('editOverlay').classList.remove('open');
  _editField = null;
}

document.getElementById('editInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') confirmEdit();
  if (e.key === 'Escape') { document.getElementById('editOverlay').classList.remove('open'); _editField=null; }
});

