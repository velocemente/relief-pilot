      btn.addEventListener('click', () => copyEtpCoord(pt, btn));
      row.appendChild(btn);

      sec.appendChild(row);
    });

    grid.appendChild(sec);
  }
}

function copyAltRoute(idx, btn) {
  const ta = document.getElementById(`ar-ta-${idx}`);
  const txt = ta ? ta.value : ((S.altRoutes[idx] || {}).route || '');
  if (!txt.trim()) { showToast('info', 'Route is empty'); return; }
  navigator.clipboard.writeText(txt).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12l5 5L20 7"/></svg>`;
    btn.style.color = 'var(--sys-green)';
    setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; }, 1600);
  }).catch(() => showToast('err', 'Copy failed — select text manually'));
}

function copyEtpCoord(pt, btn) {
  const txt = pt.lat + ' ' + pt.lon;
  navigator.clipboard.writeText(txt).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12l5 5L20 7"/></svg>';
    btn.style.color = 'var(--sys-green)';
    setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; }, 1600);
  }).catch(() => showToast('err', 'Copy failed — select text manually'));
}

// ── Evaluation engine (v1.3.0) ──────────────────────────────────────────
// Each NOTAM keyword check uses that specific NOTAM's own UTC timestamp window.
// wxWindowOverride: "HHMMz-HHMMZ" string from CFS — overrides the computed ETA±1hr window for weather.
function evalAirport(icao, etaZ, notamText, weatherText, wxWindowOverride) {
  const issues = []; let worst = 'unknown';
  const hN = notamText   && notamText.trim().length  > 0;
  const hW = weatherText && weatherText.trim().length > 0;
  if (!hN && !hW) return { color:'unknown', issues:[] };

  const etaMin = pZM(etaZ);   // ETA as minutes-of-day, null if unknown

  // ── NOTAM evaluation — per-NOTAM timestamp matching ───────────────────
  if (hN) {
    const n = notamText.toUpperCase();
    const notams = _splitNotams(notamText);   // array of individual NOTAM strings

    // Helper: get window for first notam matching keyRe, or null
    const wFor = (keyRe) => {
      for (const nm of notams) {
        if (keyRe.test(nm.toUpperCase())) return xNW(nm);
      }
      return null;
    };

    // Airport closed
    if (/\bAD\s+CLSD\b/.test(n)) {
      const w = wFor(/\bAD\s+CLSD\b/);
      const srcNm = notams.find(nm => /\bAD\s+CLSD\b/.test(nm.toUpperCase())) || '';
      if (!w || nwOverlap(w, etaMin)) {
        issues.push({level:'red', text:'🔴 Airport Closed (AD CLSD)', src:srcNm}); worst = 'red';
      } else {
        issues.push({level:'yellow', text:'⚠ AD CLSD — outside ETA window', src:srcNm}); worst = bump(worst,'yellow');
      }
    }

    // All runways closed
    if (/RWY\s+ALL\s+CLSD/.test(n)) {
      const w = wFor(/RWY\s+ALL\s+CLSD/);
      const srcNm = notams.find(nm => /RWY\s+ALL\s+CLSD/.test(nm.toUpperCase())) || '';
      if (!w || nwOverlap(w, etaMin)) {
        issues.push({level:'red', text:'🔴 All Runways Closed', src:srcNm}); worst = 'red';
      }
    }

    // Individual runway closures — check each NOTAM that mentions a closure
    const rwyMatched = new Set();
    for (const nm of notams) {
      const nu = nm.toUpperCase();
      const rm = [...nu.matchAll(/RWY\s+(\d{2}[LRC]?(?:\/\d{2}[LRC]?)?)\s+(?:CLSD|CLSD\s+EXC)/g)];
      if (!rm.length) continue;
      const w = xNW(nm);
      if (!w || nwOverlap(w, etaMin)) {
        for (const r of rm) {
          const key = r[1];
          if (!rwyMatched.has(key)) {
            rwyMatched.add(key);
            issues.push({level:'yellow', text:`⚠ RWY ${key} CLSD`, src:nm}); worst = bump(worst,'yellow');
          }
        }
      }
    }

    // Curfew / noise — check each matching NOTAM
    for (const nm of notams) {
      const nu = nm.toUpperCase();
      if (!/CURFEW|NOISE\s+ABATEMENT.*CLSD|LDG\s+CLSD|TKOF\s+CLSD/.test(nu)) continue;
      const w = xNW(nm);
      if (!w || nwOverlap(w, etaMin)) {
        issues.push({level:'red', text:'🔴 Curfew / Noise at ETA', src:nm}); worst = 'red';
      } else {
        issues.push({level:'yellow', text:'⚠ Curfew NOTAM — outside ETA window', src:nm}); worst = bump(worst,'yellow');
      }
      break; // report once per airport
    }

    // ILS / navaid (no window check — treat as advisory whenever present)
    if (/ILS.*(?:U\/S|UNREL|OTS)/.test(n) || /(?:GP|GS|LOC).*(?:U\/S|UNREL|OTS)/.test(n)) {
      const srcNm = notams.find(nm => /ILS.*(?:U\/S|UNREL|OTS)|(?:GP|GS|LOC).*(?:U\/S|UNREL|OTS)/.test(nm.toUpperCase())) || '';
      issues.push({level:'yellow', text:'⚠ ILS / GS U/S', src:srcNm}); worst = bump(worst,'yellow');
    }
    if (/(?:VOR|NDB|DME|RNAV).*(?:U\/S|UNREL|OTS)/.test(n)) {
      const srcNm = notams.find(nm => /(?:VOR|NDB|DME|RNAV).*(?:U\/S|UNREL|OTS)/.test(nm.toUpperCase())) || '';
      issues.push({level:'yellow', text:'⚠ Navaid U/S', src:srcNm}); worst = bump(worst,'yellow');
    }

    // Taxiway closures (advisory — no timestamp check needed)
    if (/TWY.*CLSD/.test(n) && !rwyMatched.size) {
      const srcNm = notams.find(nm => /TWY.*CLSD/.test(nm.toUpperCase())) || '';
      issues.push({level:'yellow', text:'ℹ Taxiway closure', src:srcNm}); worst = bump(worst,'yellow');
    }

    // Volcanic ash
    if (/VOLCANIC\s+ASH/.test(n)) {
      const srcNm = notams.find(nm => /VOLCANIC\s+ASH/.test(nm.toUpperCase())) || '';
      issues.push({level:'red', text:'🔴 Volcanic Ash NOTAM', src:srcNm}); worst = 'red';
    }

    // Alternate missed approach procedure change — check each matching NOTAM
    // Triggers on any NOTAM affecting alternate or missed approach procedure
    for (const nm of notams) {
      const nu = nm.toUpperCase();
      if (!/ALTN\s+PROC|ALTN\s+MA\b|ALTERNATE.*MISSED|MISSED.*APCH.*PROC|ALTN.*APCH\s+PROC|ALTERNATE\s+APPROACH\s+PROC|MA\s+PROC\s+ALTN|ALTN.*RWY.*PROC/.test(nu)) continue;
      const w = xNW(nm);
      if (!w || nwOverlap(w, etaMin)) {
        issues.push({level:'yellow', text:'⚠ Alternate / Missed Approach procedure change', src:nm}); worst = bump(worst,'yellow');
      } else {
        issues.push({level:'yellow', text:'ℹ Alt MA procedure change — outside ETA window', src:nm}); worst = bump(worst,'yellow');
      }
      break; // report once per airport
    }

    if (!issues.length) {
      issues.push({level:'green', text:'✓ NOTAMs reviewed — no critical items at ETA'});
    }
    worst = bump(worst, 'green');
  }

  // ── WEATHER evaluation ─────────────────────────────────────────────────
  // FOM §7.1.31 Terminal Weather Definitions (Atlas-Polar v28):
  //   Open:        Ceiling ≥ 3,000 ft  AND visibility ≥ 5 SM  → green
  //   Operational: Ceiling 1,000–3,000 ft AND visibility 3–5 SM → yellow
  //   Instruments: Ceiling 600–1,000 ft AND visibility 1–3 SM  → red
  //   Below mins:  Ceiling < 600 ft OR visibility < 1 SM        → red
  //
  // RVR: R<rwy>/<value>FT  or  R<rwy>/<value> (ICAO = metres, US = feet)
  //   US RVR feet: ≥ 4000 ft → Open; 1800–4000 → Operational; 1200–1800 → Instruments; < 1200 → Below
  //   ICAO metres: ≥ 1200 m → Open; 550–1200 → Operational; 350–550 → Instruments; < 350 → Below
  //
  // The controlling element is the worst of ceiling vs. visibility.
  // Both a green ceiling and a yellow vis = yellow overall (worst wins).
  if (hW) {
    const relevantWx = extractEtaWindow(weatherText, etaMin, wxWindowOverride);
    const wx = relevantWx.toUpperCase();
    const wxSrc = relevantWx; // raw source for tappable detail

    // Tornado (always red)
    if (/\+FC\b/.test(wx)) {
      issues.push({level:'red', text:'🔴 Tornado (+FC)', src:wxSrc}); worst = 'red';
    }

    // ── Prevailing ceiling and visibility — combined into one status row ─────
    // Per requirement: Operational/Instruments/Below triggers show both VIS and CIG.
    // Determine worst category from ceiling and vis independently, report the worst.
    const ceil = pCeil(wx);
    const vis  = pVis(wx);   // { sm, label } | null
    const rvrResult = pRVR(wx);

    // Category rank: 0=open 1=operational 2=instruments 3=below
    const ceilCat = ceil === null ? 0 : ceil >= 3000 ? 0 : ceil >= 1000 ? 1 : ceil >= 600 ? 2 : 3;
    const visCat  = vis  === null ? 0 : vis.sm >= 5  ? 0 : vis.sm >= 3  ? 1 : vis.sm >= 1 ? 2 : 3;
    const worstCat = Math.max(ceilCat, visCat);

    if (worstCat > 0) {
      const cls    = worstCat >= 2 ? 'r' : 'y';
      const visStr = vis  !== null ? `VIS <span class="wx-val ${cls}">${vis.label}</span>` : null;
      const cigStr = ceil !== null ? `CIG <span class="wx-val ${cls}">${ceil}ft</span>`    : null;
      const parts  = [visStr, cigStr].filter(Boolean).join(' &nbsp;');

      let prefix, level;
      if      (worstCat === 1) { prefix = '⚠ Operational';  level = 'yellow'; }
      else if (worstCat === 2) { prefix = '🔴 Instruments';  level = 'red';    }
      else                     { prefix = '🔴';               level = 'red';    }

      issues.push({level, text:`${prefix} — ${parts}`, src:wxSrc});
      worst = bump(worst, level);
    }

    // RVR evaluation — overrides or supplements prevailing vis
    if (rvrResult !== null) {
      const { ft, label } = rvrResult;
      let rvrLevel, rvrClass, rvrPrefix;
      if (ft >= 4000) {
        rvrLevel = null; rvrClass = 'g'; rvrPrefix = null;  // Open — no alert
      } else if (ft >= 1800) {
        rvrLevel = 'yellow'; rvrClass = 'y'; rvrPrefix = '⚠ Operational';
      } else if (ft >= 1200) {
        rvrLevel = 'red'; rvrClass = 'r'; rvrPrefix = '🔴 Instruments';
      } else {
        rvrLevel = 'red'; rvrClass = 'r'; rvrPrefix = '🔴';
      }
      if (rvrLevel) {
        issues.push({level:rvrLevel, text:`${rvrPrefix} — RVR <span class="wx-val ${rvrClass}">${label}</span>`, src:wxSrc});
        worst = bump(worst, rvrLevel);
      }
    }

    // TEMPO ceiling/vis — flag any degradation into Instruments or worse
    const tc = pGCeil(wx, 'TEMPO');
    const tv = pGVis(wx,  'TEMPO');   // { sm, label } | null
    if (tc !== null && tc < 1000) {
      const cls = tc < 600 ? 'r' : 'r';
      issues.push({level:'red', text:`🔴 TEMPO CIG <span class="wx-val ${cls}">${tc}ft</span>`, src:wxSrc}); worst = 'red';
    } else if (tc !== null && tc < 3000) {
      issues.push({level:'yellow', text:`⚠ TEMPO CIG <span class="wx-val y">${tc}ft</span>`, src:wxSrc}); worst = bump(worst,'yellow');
    }
    if (tv !== null && tv.sm < 3) {
      issues.push({level:'red', text:`🔴 TEMPO VIS <span class="wx-val r">${tv.label}</span>`, src:wxSrc}); worst = 'red';
    } else if (tv !== null && tv.sm < 5) {
      issues.push({level:'yellow', text:`⚠ TEMPO VIS <span class="wx-val y">${tv.label}</span>`, src:wxSrc}); worst = bump(worst,'yellow');
    }

    // PROB30 + significant weather — advisory
    if (/PROB30/.test(wx) && /TS|FZRA|\+SN|\+RA/.test(wx)) {
      issues.push({level:'yellow', text:'⚠ PROB30 + significant wx', src:wxSrc}); worst = bump(worst,'yellow');
    }

    if (/\bTS\b|\bTSRA\b/.test(wx)) {
      issues.push({level:'yellow', text:'⚠ Thunderstorm in forecast', src:wxSrc}); worst = bump(worst,'yellow');
    }
    if (/FZRA|FZDZ/.test(wx)) {
      issues.push({level:'yellow', text:'⚠ Freezing precip', src:wxSrc}); worst = bump(worst,'yellow');
    }
    if (/WS\d{3}\/|LLWS|WINDSHEAR/.test(wx)) {
      issues.push({level:'yellow', text:'⚠ Windshear', src:wxSrc}); worst = bump(worst,'yellow');
    }
    if (/\bFG\b|\bFZFG\b/.test(wx)) {
      issues.push({level:'yellow', text:'⚠ Fog', src:wxSrc}); worst = bump(worst,'yellow');
    }

    // If no issues found, weather is Open
    if (!issues.filter(i => i.level !== 'green').length) {
      const visStr  = vis  !== null ? `, VIS ${vis.label}`  : '';
      const ceilStr = ceil !== null ? ` (CIG ${ceil}ft${visStr})` : '';
      issues.push({level:'green', text:`✓ Open — wx at or above mins${ceilStr}`});
    }
  }

  if (worst === 'unknown' && (hN || hW)) worst = 'green';
  return { color: worst, issues };
}

// ── TAF window extractor ─────────────────────────────────────────────────
// Returns the substring of weatherText covering groups that overlap ETA ±60 min.
// If ETA is unknown or no TAF found, returns full weatherText.
//
// TAF group types handled:
//   Base:  "TAF [AMD] ICAO DDHHmmZ DDHH/DDHH conditions..."
//   FM:    "FM DDHHMM conditions..."  (valid until next FM or end of TAF)
//   TEMPO: "TEMPO DDHH/DDHH conditions..."
//   BECMG: "BECMG DDHH/DDHH conditions..."
//   PROB:  "PROB30 DDHH/DDHH" / "PROB40 DDHH/DDHH"
//
// All day-hours converted to absolute minutes (day*1440 + HH*60 + MM).
// ETA window = etaDay*1440 + etaMin ± 60.
function extractEtaWindow(weatherText, etaMin, wxWindowOverride) {
  if (etaMin === null && !wxWindowOverride) return weatherText;

  // Determine flight date day-of-month from _flightDateISO for day anchoring
  const iso = window._flightDateISO; // "YYYY-MM-DD"
  const flightDay = iso ? parseInt(iso.slice(8,10)) : null;

  // Convert DDHH or DDHHMM to absolute minutes (DD * 1440 + HH*60 + MM)
  function toAbsMin(dd, hh, mm) {
    return parseInt(dd)*1440 + parseInt(hh)*60 + (mm ? parseInt(mm) : 0);
  }

  // ETA absolute minutes — anchor on flight day
  const etaDay = flightDay || 1;
  let winStart, winEnd;

  if (wxWindowOverride) {
    // CFS airport: use OFP-provided WX WINDOW exactly ("HHMMz-HHMMZ")
    const wm = wxWindowOverride.match(/(\d{4})Z-(\d{4})Z/i);
    if (wm) {
      const wsMin = parseInt(wm[1].slice(0,2))*60 + parseInt(wm[1].slice(2,4));
      const weMin = parseInt(wm[2].slice(0,2))*60 + parseInt(wm[2].slice(2,4));
      winStart = etaDay * 1440 + wsMin;
      winEnd   = etaDay * 1440 + weMin;
      if (winEnd < winStart) winEnd += 1440; // crosses midnight
    } else {
      winStart = etaDay * 1440 + (etaMin||0) - 60;
      winEnd   = etaDay * 1440 + (etaMin||0) + 60;
    }
  } else {
    const etaAbs = etaDay * 1440 + etaMin;
    winStart = etaAbs - 60;
    winEnd   = etaAbs + 60;
  }

  // Try to extract only the TAF section
  const tafMatch = weatherText.match(/TAF(?:\s+AMD)?\s+[A-Z]{4}[\s\S]*/i);
  if (!tafMatch) return weatherText; // no TAF — return full text (METAR only)
  const taf = tafMatch[0];

  // Split TAF into groups at FM / TEMPO / BECMG / PROB boundaries + base group
  // Regex splits on group-start keywords, keeping delimiters
  const groupRe = /(?=\bFM\d{6}\b|\bTEMPO\b|\bBECMG\b|\bPROB\d{2}\b)/g;
  const parts = taf.split(groupRe);
  if (parts.length <= 1) return weatherText; // can't split, return all

  // Parse TAF header for base validity: DDHH/DDHH
  const hdrM = taf.match(/TAF(?:\s+AMD)?\s+[A-Z]{4}\s+\d{6}Z\s+(\d{2})(\d{2})\/(\d{2})(\d{2})/i);
  let tafEndAbs = winEnd + 120; // fallback
  if (hdrM) {
    tafEndAbs = toAbsMin(hdrM[3], hdrM[4], 0);
    if (tafEndAbs < toAbsMin(hdrM[1], hdrM[2], 0)) tafEndAbs += 7*1440; // wrap (unlikely)
  }

  // Build FM group list with start times, to determine each group's end
  const fmGroups = [];
  for (const p of parts) {
    const fm = p.match(/^FM(\d{2})(\d{2})(\d{2})/);
    if (fm) fmGroups.push({ abs: toAbsMin(fm[1], fm[2], fm[3]), text: p });
  }

  const relevant = [];
  for (let i = 0; i < parts.length; i++) {
    const p = parts[i];

    // FM group — valid from start until next FM group or TAF end
    const fm = p.match(/^FM(\d{2})(\d{2})(\d{2})/);
    if (fm) {
      const gStart = toAbsMin(fm[1], fm[2], fm[3]);
      const nextFm = fmGroups.find(g => g.abs > gStart);
      const gEnd   = nextFm ? nextFm.abs : tafEndAbs;
      if (gStart < winEnd && gEnd > winStart) relevant.push(p);
      continue;
    }

    // TEMPO / BECMG / PROB — have explicit DDHH/DDHH window
    const wm = p.match(/^(?:TEMPO|BECMG|PROB\d{2})\s+(\d{2})(\d{2})\/(\d{2})(\d{2})/i);
    if (wm) {
      const gStart = toAbsMin(wm[1], wm[2], 0);
      const gEnd   = toAbsMin(wm[3], wm[4], 0);
      const effEnd = gEnd <= gStart ? gEnd + 1440 : gEnd; // midnight wrap
      if (gStart < winEnd && effEnd > winStart) relevant.push(p);
      continue;
    }

    // Base group (everything before first FM/TEMPO/BECMG) — always include
    if (i === 0) relevant.push(p);
  }

  // If nothing matched (e.g. ETA far outside TAF validity), return base + all
  return relevant.length ? relevant.join('\n') : taf;
}

// ═══════════════════════════════════════════════════════
//  NOTAM DATE/TIME PARSING  (v1.2.0)
//
//  Atlas/Polar OFP NOTAM format:
//    - ICAO NNNN/YY (SERIES/NUM) DDMMMHHmm-DDMMMHHmm [YYYY] [EST]
//  Examples from live OFP:
//    06MAR0800-06MAR1400          → day 6 Mar 0800Z to 1400Z (year from OFP date)
//    05MAR2354-06MAR2354          → spans midnight
//    20JAN2024-15JUN1500          → long-running (start year inferred, end year explicit)
//    31MAY2200 2026               → trailing year on end date
//    12FEB0423-PERM               → permanent → treated as always active
//
//  Resolution: parse each date-token as DDMMMHHmmZ using OFP flight year as
//  the base year. When end month < start month the end year is incremented.
//  All times expressed as UTC milliseconds for unambiguous comparison.
// ═══════════════════════════════════════════════════════

const _MON = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};

// Parse a single NOTAM date-token "DDMMMHHmm" → UTC ms.
// baseYear: flight year from _flightDateISO. endYear: explicit trailing year if present.
function _parseNotamToken(token, baseYear, endYear) {
  const m = token.match(/^(\d{2})(JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)(\d{4})$/i);
  if (!m) return null;
  const dd = parseInt(m[1]);
  const mo = _MON[m[2].toUpperCase()];
  const hh = parseInt(m[3].slice(0, 2));
  const mi = parseInt(m[3].slice(2, 4));
  const yr = endYear || baseYear || new Date().getUTCFullYear();
  return Date.UTC(yr, mo, dd, hh, mi);
}

// Extract UTC window {startMs, endMs} from a single NOTAM line or block.
// Returns null if no parseable timestamps found (→ treated as always active).
function xNW(notamLine) {
  const iso  = window._flightDateISO;                   // "YYYY-MM-DD"
  const baseYear = iso ? parseInt(iso.slice(0, 4)) : new Date().getUTCFullYear();

  // Pattern: DDMMMHHmm-DDMMMHHmm [YYYY] | DDMMMHHmm-PERM
  const re = /(\d{2}(?:JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)\d{4})-(\d{2}(?:JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)\d{4}|PERM)(?:\s+(\d{4}))?/i;
  const m = notamLine.match(re);
  if (!m) return null;

  // PERM → end is far future; start year = baseYear
  if (/^PERM$/i.test(m[2])) {
    const sMs = _parseNotamToken(m[1], baseYear, baseYear);
    if (sMs === null) return null;
    return { startMs: sMs, endMs: Date.UTC(baseYear + 50, 0, 1) };
  }

  // Month indices for year inference
  const startMo = _MON[m[1].slice(2, 5).toUpperCase()];
  const endMo   = _MON[m[2].slice(2, 5).toUpperCase()];

  // Explicit trailing year on the end token (e.g. "31MAR2359 2026")
  const trailingYear = m[3] ? parseInt(m[3]) : null;

  // End year: explicit trailing > inferred (cross-month → next year) > baseYear
  const endYear   = trailingYear || (endMo < startMo ? baseYear + 1 : baseYear);

  // Start year: if the NOTAM crosses a calendar year boundary,
  // the start must be in the previous year (e.g. 29DEC→31MAR crosses Dec/Jan)
  const startYear = (endMo < startMo) ? endYear - 1 : endYear;

  const startMs = _parseNotamToken(m[1], baseYear, startYear);
  const endMs   = _parseNotamToken(m[2], baseYear, endYear);
  if (startMs === null || endMs === null) return null;

  return { startMs, endMs };
}

// Does a NOTAM UTC window overlap with ETA ±60 min?
// etaMin = minutes-of-day (0-1439). etaDate anchored to _flightDateISO.
function nwOverlap(w, etaMin) {
  if (etaMin === null) return true;           // no ETA known → treat as active
  const iso = window._flightDateISO;
  if (!iso) return true;                      // no flight date → treat as active
  const etaMs   = new Date(iso + 'T00:00:00Z').getTime()
                  + Math.floor(etaMin / 60) * 3600000
                  + (etaMin % 60) * 60000;
  const winStart = etaMs - 3600000;           // ETA − 1 hour
  const winEnd   = etaMs + 3600000;           // ETA + 1 hour
  return w.startMs < winEnd && w.endMs > winStart;
}

// Back-compat alias (used in tests/compat calls)
function oETA(w, etaMin) { return nwOverlap(w, etaMin); }

// Split a NOTAM text blob into individual NOTAM entries.
// Each entry starts with "- ICAO" (Atlas/Polar OFP format).
function _splitNotams(text) {
  // Split on lines beginning with "- XXXX" where XXXX is a 4-letter ICAO
  const parts = text.split(/^(?=- [A-Z]{4}\b)/m).filter(s => s.trim());
  return parts.length > 1 ? parts : [text]; // fallback: treat as single block
}

// Find the NOTAM window for the first NOTAM in a blob that matches a keyword regex.
// Returns xNW result for that specific NOTAM, or null if not found / no timestamp.
function _notamWindow(text, keywordRe) {
  const notams = _splitNotams(text);
  for (const n of notams) {
    if (keywordRe.test(n.toUpperCase())) {
      return xNW(n);
    }
  }
  return null;
}

// Keep oETA as alias for back-compatibility
// (already declared above)
function bump(a,b){const o=['unknown','green','yellow','red'];return o.indexOf(b)>o.indexOf(a)?b:a;}

// Micro-parsers (used by evalAirport)
function pZM(s){if(!s)return null;const c=s.replace(/\D/g,'');if(c.length<4)return null;return parseInt(c.slice(0,2))*60+parseInt(c.slice(2,4));}

// pCeil: lowest BKN or OVC layer in feet (returns null if none)
function pCeil(wx){const m=[...wx.matchAll(/(?:BKN|OVC)(\d{3})/g)];if(!m.length)return null;return Math.min(...m.map(x=>parseInt(x[1])*100));}

// pVis: prevailing visibility
// Returns { sm: number, label: string } or null.
//   sm    — visibility in statute miles (for category threshold comparison)
//   label — display string with correct unit ("10SM", "9999m", "5.0KM", "1 1/2SM")
//
// Handles all ICAO/FAA formats:
//   SM group:    P6SM | \d{1,2}SM | \d \d/\dSM | \d/\dSM  → label shows "SM"
//   KM group:    \d{1,3}KM                                 → label shows "KM"
//   ICAO metres: standalone 4-digit token, 0000–9999, not a time/period group
//                9999 → ">10km" label; others → label shows "m"
//
// Exclusion rules for 4-digit metre tokens:
//   - Must be preceded by space (not part of a longer number)
//   - NOT followed by / (would be a TAF period like 0604/0606)
//   - NOT followed by Z (would be a Zulu time group)
//   - NOT followed by KT/MH/PS (would be wind)
function pVis(wx) {
  // Strip RVR groups first so R28L/0600 doesn't confuse the metre scanner
  const w = wx.replace(/\bR\d{2}[LRC]?\/[MP]?\d+(?:FT)?\b/g, '');

  // P6SM
  if (/\bP6SM\b/.test(w)) return { sm: 7, label: 'P6SM' };

  // SM: whole + fraction  (e.g. "1 1/2SM")
  let m = w.match(/(?<!\d)(\d{1,2})\s+(\d)\/(\d+)SM\b/);
  if (m) {
    const sm = parseInt(m[1]) + parseInt(m[2]) / parseInt(m[3]);
    return { sm, label: `${m[1]} ${m[2]}/${m[3]}SM` };
  }
  // SM: fraction only (e.g. "1/4SM")
  m = w.match(/(?<!\d)(\d)\/(\d+)SM\b/);
  if (m) {
    const sm = parseInt(m[1]) / parseInt(m[2]);
    return { sm, label: `${m[1]}/${m[2]}SM` };
  }
  // SM: whole number (e.g. "10SM", "3SM")
  m = w.match(/(?<!\d)(\d{1,2})SM\b/);
  if (m) return { sm: parseFloat(m[1]), label: `${m[1]}SM` };

  // KM (e.g. "9KM", "10KM")
  m = w.match(/(?<!\d)(\d{1,3})KM\b/);
  if (m) {
    const km = parseFloat(m[1]);
    return { sm: km * 0.6214, label: `${m[1]}KM` };
  }

  // ICAO 4-digit metres — standalone token only
  for (const tm of w.matchAll(/(?<!\d)(\d{4})(?!\d)/g)) {
    const pos  = tm.index;
    const val  = parseInt(tm[1]);
    const prev = pos > 0 ? w[pos - 1] : ' ';
    const next = w.slice(tm.index + 4, tm.index + 6);

    if (prev !== ' ') continue;             // must be space-separated
    if (/^[\/Z]/.test(next)) continue;      // TAF period (0604/0606) or Zulu time
    if (/^(KT|MH|PS)/.test(next)) continue; // wind group

    if (val === 9999) return { sm: 7, label: '9999m' };
    if (val <= 9999)  return { sm: val / 1609.34, label: `${val}m` };
  }

  return null;
}

// pRVR: parse the worst (lowest) RVR value from the weather text
// Formats: R28L/2400FT  R28/2400  R28L/M0600FT  R10C/1200  (ICAO m) R10/4000FT (US ft)
// Returns { ft: number, label: string } | null
// US airports use feet (presence of "FT" suffix or values ≥ 600 with no "M" prefix and context).
// ICAO airports use metres (no FT suffix, 3-4 digit value < 2000 context).
// For US: if "FT" present or value ≥ 600 with no FT → ambiguous, default to ft for values ≥ 600.
// Heuristic: if the text already contains SM or METAR US format → ft; otherwise → metres.
function pRVR(wx) {
  // Match all RVR entries: R<rwy>/<M?><value><FT?>
  const rvrRe = /\bR(\d{2}[LRC]?)\/([MP]?)(\d+)(FT)?/g;
  const matches = [...wx.matchAll(rvrRe)];
  if (!matches.length) return null;

  const isUS = /\bSM\b/.test(wx);  // SM present → US METAR → values are in feet
  let worstFt = Infinity;
  let worstLabel = '';

  for (const m of matches) {
    const rwy     = m[1];
    const prefix  = m[2]; // 'M' = less than, 'P' = more than
    const val     = parseInt(m[3]);
    const hasFT   = !!m[4];
    if (prefix === 'P') continue; // "more than" — not a restriction

    let ft;
    if (hasFT || isUS) {
      ft = val;  // already feet
    } else {
      // ICAO metres — convert to feet for thresholds
      ft = Math.round(val * 3.281);
    }

    if (ft < worstFt) {
      worstFt = ft;
      // Build display label
      if (hasFT || isUS) {
        worstLabel = `R${rwy}/${prefix}${val}FT`;
      } else {
        worstLabel = `R${rwy}/${prefix}${val}m`;
      }
    }
  }

  return worstFt === Infinity ? null : { ft: worstFt, label: worstLabel };
}

// pGCeil: lowest BKN/OVC ceiling in a named group (e.g. TEMPO)
function pGCeil(wx,g){const re=new RegExp(`${g}[^A-Z]*(BKN|OVC)(\\d{3})`,'g');const m=[...wx.matchAll(re)];if(!m.length)return null;return Math.min(...m.map(x=>parseInt(x[2])*100));}

// pGVis: lowest visibility in a named TAF group (e.g. TEMPO, BECMG)
// Returns { sm, label } or null — same shape as pVis()
function pGVis(wx, g) {
  const re = new RegExp(`${g}\\b([\\s\\S]*?)(?=BECMG|TEMPO|PROB|FM\\d{6}|$)`, 'g');
  let worst = null;
  for (const gm of wx.matchAll(re)) {
    const block = gm[1];
    const v = pVis(block);
    if (v !== null && (worst === null || v.sm < worst.sm)) worst = v;
  }
  return worst;
}

