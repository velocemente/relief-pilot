function z2l(hmm, icao) {
  const c = (hmm || '').replace(/\D/g, '');
  if (c.length < 4) return '____L';
  const hh = parseInt(c.slice(0, 2), 10);
  const mm = parseInt(c.slice(2, 4), 10);
  // Each airport uses its own IANA timezone; anchored to today's date for correct DST
  const tz = ICAO_TZ[(icao || '').toUpperCase()] || 'UTC';
  const now = new Date();
  const utc = new Date(Date.UTC(
    now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(),
    hh, mm, 0
  ));
  try {
    const fmt = new Intl.DateTimeFormat('en-GB', {
      timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false
    });
    const parts = fmt.formatToParts(utc);
    const lh = parts.find(p => p.type === 'hour')?.value  || '00';
    const lm = parts.find(p => p.type === 'minute')?.value || '00';
    return String(parseInt(lh, 10) % 24).padStart(2, '0') + lm + 'L';
  } catch {
    return hmm + 'L?';
  }
}

