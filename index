  if (etpPoints.length) {
    const sec = document.createElement('div');
    sec.className = 'section etp-section';

    const heading = document.createElement('div');
    heading.className = 'etp-section-title';
    heading.textContent = 'ETP Coordinates';
    sec.appendChild(heading);

    etpPoints.forEach(pt => {
      const row = document.createElement('div');
      row.className = 'etp-point-row';

      const lbl = document.createElement('span');
      lbl.className = 'etp-point-label';
      lbl.textContent = pt.name;
      row.appendChild(lbl);

      const coord = document.createElement('span');
      coord.className = 'etp-point-coord';
      coord.textContent = pt.lat + '  ' + pt.lon;
      row.appendChild(coord);

      const btn = document.createElement('button');
      btn.className = 'etp-copy-btn';
      btn.setAttribute('aria-label', 'Copy ' + pt.name + ' coordinates');
