//  AIRPORT STATUS ENGINE
// ═══════════════════════════════════════════════════════
function getAllAirports() {
  const orig=(S.origIcao||'').toUpperCase();
  const dest=(S.destIcao||'').toUpperCase();
  const apts=[];
  if(orig) apts.push({icao:orig, role:'ORIG', eta:null, depTime:S.outZ});
  if(dest) apts.push({icao:dest, role:'DEST', eta:S.etaDest});
  (S.altData||[]).forEach(a => {
    if(a.icao!==orig && a.icao!==dest)
      apts.push({icao:a.icao, role:a.role, eta:a.currentEta,
                 wxWindow: a.wxWindow||null, etpName: a.etpName||null});
  });
  return apts;
}

// ── Render airport issue rows ─────────────────────────────────────────────
// Issues with a src field are tappable — tap opens a read-only detail sheet
// showing the raw NOTAM entry or TAF group that caused the alert.
// src is URI-encoded to safely pass through onclick without injection risk.
function renderIssueRows(issues) {
  if (!issues || !issues.length) {
    return `<div class="apt-issue g">✓ No issues at ETA window</div>`;
  }
  return issues.map(i => {
    const cls = i.level.charAt(0);
    if (i.src && i.src.trim()) {
      // Tappable: encode src so it survives the onclick string safely
      const encoded = encodeURIComponent(i.src.trim());
      // Label = first 40 chars of text stripped of emoji/HTML
      const labelRaw = i.text.replace(/<[^>]+>/g,'').replace(/^[🔴⚠✓ℹ🟢🟡⚪]+\s*/,'').slice(0,50);
      return `<div class="apt-issue ${cls} tappable" role="button" aria-label="View source for: ${labelRaw}" onclick="showIssueDetail('${encoded}','${labelRaw.replace(/'/g,'&#39;')}','${i.level}')">` +
             `<span class="apt-issue-text">${i.text}</span>` +
             `<svg class="apt-issue-chevron" viewBox="0 0 9 14" aria-hidden="true"><path d="M1 1l6.5 6L1 13"/></svg>` +
             `</div>`;
    }
    return `<div class="apt-issue ${cls}">${i.text}</div>`;
  }).join('');
}

function buildAirportCards() {
  const grid = document.getElementById('airportGrid');
  const empty = document.getElementById('emptyAirports');
  const apts = getAllAirports();

  if (!apts.length) { empty.style.display='flex'; return; }
  empty.style.display='none';

  // Remove old cards, keep empty state
  [...grid.querySelectorAll('.apt-card')].forEach(c=>c.remove());

  apts.forEach(apt => {
    if (!airportData[apt.icao]) airportData[apt.icao]={notams:'',weather:''};
    const data = airportData[apt.icao];
    const status = evalAirport(apt.icao, apt.eta, data.notams, data.weather, apt.wxWindow);
    const sc = {green:'g',yellow:'y',red:'r',unknown:'u'}[status.color];
    const sl = {green:'CLEAR',yellow:'REVIEW',red:'ALERT',unknown:'NO DATA'}[status.color];
    const dotColor = {green:'var(--sys-green)',yellow:'var(--sys-yellow)',red:'var(--sys-red)',unknown:'var(--label3)'}[status.color];
    const etaDisplay = apt.role === 'ORIG'
      ? (apt.depTime ? `DEP ${apt.depTime}Z` : '')
      : (apt.eta    ? `ETA ${apt.eta}Z`      : '');
    // WX window: for CFS use OFP-provided window; for others compute ETA ±1hr per FOM §121.619
    let wxWindowStr = '';
    if (apt.wxWindow) {
      // CFS airport — show OFP window verbatim (already "HHMMz-HHMMZ")
      wxWindowStr = `WX ${apt.wxWindow.replace('Z-','Z–')}`;
    } else if (apt.role !== 'ORIG' && apt.eta && apt.eta.length === 4) {
      const em = parseInt(apt.eta.slice(0,2))*60 + parseInt(apt.eta.slice(2,4));
      const wStart = (em - 60 + 1440) % 1440;
      const wEnd   = (em + 60) % 1440;
      const fmt4 = n => String(Math.floor(n/60)).padStart(2,'0') + String(n%60).padStart(2,'0');
      wxWindowStr = `WX ${fmt4(wStart)}–${fmt4(wEnd)}Z`;
    }

    // ── Curfew evaluation for this airport ──
    const cf = evalCurfew(apt.icao, apt.eta);
    const hasCurfew = cf.color !== 'none';
    const curfewColor = { green:'var(--sys-green)', yellow:'var(--sys-yellow)', red:'var(--sys-red)' }[cf.color] || '';
    const curfewLabel = cf.color === 'red'   ? 'CURFEW' :
                        cf.color === 'yellow' ? 'CURFEW' : 'CURFEW ✓';
    // Delta label: "inside", "45 min", "2 hr 10 min"
    let curfewDeltaStr = '';
    if (hasCurfew) {
      if (cf.delta === 0 || cf.delta === null) {
        curfewDeltaStr = cf.delta === 0 ? 'ETA INSIDE CURFEW' : 'Check times';
      } else {
        const h = Math.floor(cf.delta / 60), m = cf.delta % 60;
        curfewDeltaStr = h > 0 ? `${h} hr${m ? ' ' + m + ' min' : ''} to window` : `${m} min to window`;
      }
    }

    const card = document.createElement('div');
    card.className = 'apt-card section';
    card.id = `apc-${apt.icao}`;
    card.innerHTML = `
      <div class="apt-card-header" onclick="toggleAptInputs('${apt.icao}')" aria-expanded="false" role="button">
        <div class="apt-status-indicator" style="background:${dotColor}"></div>
        <div class="apt-card-titles">
          <div class="apt-card-icao">${apt.icao}</div>
          <div class="apt-card-role">${apt.role}</div>
        </div>
        <div class="apt-eta-block">
          ${etaDisplay ? `<div class="apt-eta-tag">${etaDisplay}</div>` : ''}
          ${wxWindowStr ? `<div class="apt-wx-window">${wxWindowStr}</div>` : ''}
        </div>
        <div class="apt-badge ${sc}">${sl}</div>
        <svg class="cell-chevron" viewBox="0 0 9 14" aria-hidden="true" style="transform:rotate(90deg)"><path d="M1 1l6.5 6L1 13"/></svg>
      </div>
      <div class="apt-issues-list" id="api-${apt.icao}">
        ${renderIssueRows(status.issues)}
      </div>
      ${hasCurfew ? `
      <div class="apt-curfew-row" onclick="showCurfewDetail('${apt.icao}')" role="button" aria-label="Curfew detail for ${apt.icao}" style="border-top:0.5px solid var(--sep)">
        <svg viewBox="0 0 24 24" fill="none" stroke="${curfewColor}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span class="apt-curfew-label" style="color:${curfewColor}">${curfewLabel}</span>
        <span class="apt-curfew-delta">${esc(curfewDeltaStr)}</span>
        <svg viewBox="0 0 9 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:7px;height:11px;flex-shrink:0;color:var(--label3)"><path d="M1 1l6.5 6L1 13"/></svg>
      </div>` : ''}
      <div class="apt-inputs" id="api-in-${apt.icao}">
        <div class="apt-input-row">
          <div class="apt-input-label">NOTAM</div>
          <textarea class="apt-input-ta ta-notam" id="ta-notam-${apt.icao}" placeholder="Paste NOTAMs…" aria-label="${apt.icao} NOTAMs" oninput="updateApt('${apt.icao}','notams',this.value)"></textarea>
        </div>
        <div class="apt-input-row">
          <div class="apt-input-label">WX</div>
          <textarea class="apt-input-ta ta-wx" id="ta-wx-${apt.icao}" placeholder="Paste TAF / METAR…" aria-label="${apt.icao} weather" oninput="updateApt('${apt.icao}','weather',this.value)"></textarea>
        </div>
      </div>`;
    grid.appendChild(card);
    // [S9] User-controlled text (notams/weather) is never embedded in the
    // innerHTML template. Set textarea values imperatively via .value on the
    // live DOM nodes, preventing any </textarea><script> breakout vector.
    const taN = document.getElementById(`ta-notam-${apt.icao}`);
    const taW = document.getElementById(`ta-wx-${apt.icao}`);
    if (taN) taN.value = data.notams  || '';
    if (taW) taW.value = data.weather || '';
  });
}

function showCurfewDetail(icao) {
  const cf = evalCurfew(icao, (getAllAirports().find(a=>a.icao===icao)||{}).eta);
  if (!cf.detail) return;
  const deltaStr = cf.delta === 0 ? 'ETA is inside a curfew window'
    : cf.delta == null ? ''
    : (() => { const h=Math.floor(cf.delta/60),m=cf.delta%60; return (h?`${h} hr `:'')+(m?`${m} min `:'')+`to nearest curfew boundary`; })();
  document.getElementById('editLabel').textContent = `${icao} — Curfew${deltaStr ? '  ·  ' + deltaStr : ''}`;
  // Use the pre block for wrapped display
  const inp = document.getElementById('editInput');
  const pre = document.getElementById('issueDetailPre');
  inp.style.display = 'none';
  pre.textContent = cf.detail.trim();
  pre.classList.add('active');
  document.getElementById('editOverlay').classList.add('open');
  _editField = '__curfew__';
}

// Show the raw source text that triggered an alert.
// Uses a <pre> block instead of the <input> so multi-line NOTAM text wraps
// correctly and displays in full — <input> is single-line only.
function showIssueDetail(encodedSrc, label, level) {
  const src = decodeURIComponent(encodedSrc);
  if (!src.trim()) return;

  document.getElementById('editLabel').textContent = label;

  // Hide the normal edit input, show the pre detail block
  const inp = document.getElementById('editInput');
  const pre = document.getElementById('issueDetailPre');
  inp.style.display = 'none';
  pre.textContent = src.trim();   // textContent: safe — no HTML injection
  pre.classList.add('active');

  document.getElementById('editOverlay').classList.add('open');
  _editField = '__curfew__';
}

function toggleAptInputs(icao) {
  const inp = document.getElementById(`api-in-${icao}`);
  const open = inp.style.display === 'flex';
  inp.style.display = open ? 'none' : 'flex';
  inp.style.flexDirection = 'column';
}

function updateApt(icao, field, value) {
  if (!airportData[icao]) airportData[icao]={notams:'',weather:''};
  airportData[icao][field] = value;
  refreshAptCard(icao);
  renderNote();
}

function refreshAptCard(icao) {
  const card = document.getElementById(`apc-${icao}`); if (!card) return;
  const apt = getAllAirports().find(a=>a.icao===icao); if (!apt) return;
  const data = airportData[icao]||{notams:'',weather:''};
  const status = evalAirport(icao, apt.eta, data.notams, data.weather);
  const sc = {green:'g',yellow:'y',red:'r',unknown:'u'}[status.color];
  const sl = {green:'CLEAR',yellow:'REVIEW',red:'ALERT',unknown:'NO DATA'}[status.color];
  const dotColor={green:'var(--sys-green)',yellow:'var(--sys-yellow)',red:'var(--sys-red)',unknown:'var(--label3)'}[status.color];
  card.querySelector('.apt-status-indicator').style.background = dotColor;
  const badge = card.querySelector('.apt-badge');
  badge.className = `apt-badge ${sc}`; badge.textContent = sl;
  const issues = document.getElementById(`api-${icao}`);
  if (issues) issues.innerHTML = renderIssueRows(status.issues);
}

